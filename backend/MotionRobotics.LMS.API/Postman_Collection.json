{
"info": {
  "name": "Motion Robotics LMS API",
  "description": "Complete API testing collection for Motion Robotics Learning Management System - Admin is auto-created at startup",
  "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
},
"item": [
  {
    "name": "1. ADMIN AUTH",
    "item": [
      {
        "name": "Admin Login",
        "event": [
          {
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  var jsonData = pm.response.json();",
                "  pm.environment.set(\"admin_token\", jsonData.token);",
                "  pm.environment.set(\"admin_email\", jsonData.adminEmail);",
                "}"
              ]
            }
          }
        ],
        "request": {
          "method": "POST",
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": {
            "mode": "raw",
            "raw": "{\n  \"email\": \"admin@motionrobotics.com\",\n  \"password\": \"Admin@123\"\n}"
          },
          "url": {
            "raw": "{{base_url}}/admin/auth/login",
            "host": [
              "{{base_url}}"
            ],
            "path": [
              "admin",
              "auth",
              "login"
            ]
          }
        }
      }
    ]
  },
