{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "your-production-domain.com",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "SecretKey": "",
    "Issuer": "MotionRobotics",
    "Audience": "MotionRoboticsUsers",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "Session": {
    "SuperAdminExpiryHours": 4,
    "SchoolAdminExpiryHours": 8,
    "AdminExpiryHours": 6,
    "TeacherExpiryHours": 10,
    "StudentExpiryHours": 12,
    "CleanupOlderThanDays": 14
  },
  "SuperAdmin": {
    "Email": "",
    "Password": ""
  },
  "Cors": {
    // Add your Vercel URL here or set via Cors__AllowedOrigins__0 env var on Render.
    // Leaving this empty will cause the app to fail fast on startup (intentional).
    "AllowedOrigins": []
  }
}
